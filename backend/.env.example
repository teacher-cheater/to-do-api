APP_NAME="To-Do API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Эти значения используются, только если backend запускается БЕЗ
# Docker (см. "Запуск без Docker" в README) — тогда backend работает
# на хосте и подключается к MySQL через порт 3306, проброшенный из
# контейнера (127.0.0.1). Если backend запущен через
# `docker compose up` — значения ниже не важны: docker-compose.yml
# передаёт свои DB_HOST=mysql и т.д. через environment: и они
# перекрывают этот файл (переменные окружения контейнера имеют
# приоритет над .env).
DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=todo
DB_USERNAME=todo
DB_PASSWORD=secret

# Альтернатива без MySQL вообще — SQLite (тоже только для запуска без Docker):
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=cookie
SESSION_LIFETIME=120

# Используется только config/cors.php, чтобы разрешить браузерные
# запросы с фронтенда (обычный CORS, без cookie/credentials —
# авторизация у нас через заголовок Authorization: Bearer, см. README).
FRONTEND_URL=http://localhost:3000
